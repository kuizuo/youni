# Cloudflare deploy credentials for Alchemy.
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""

# Web build binding.
VITE_SERVER_URL="https://your-server.example.com"

# Server bindings.
CORS_ORIGIN="https://your-web.example.com"
BETTER_AUTH_SECRET="replace-with-a-random-secret-at-least-32-characters"
BETTER_AUTH_URL="https://your-server.example.com"
ADMIN_EMAILS="admin@youni.local"

# Google OAuth / AI.
GOOGLE_GENERATIVE_AI_API_KEY=""
GOOGLE_WEB_CLIENT_ID=""
GOOGLE_IOS_CLIENT_ID=""
GOOGLE_ANDROID_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Alchemy creates and binds the Cloudflare D1 database named `youni` as `DB`.
# The same account/token can be used by `bun run db:seed` with `CLOUDFLARE_D1_DATABASE_ID`.
CLOUDFLARE_D1_DATABASE_ID=""
CLOUDFLARE_D1_API_TOKEN=""

# Alchemy creates and binds the Cloudflare R2 bucket named `youni` as `YOUNI_BUCKET`.
# Avatar objects are stored under the `avatar/` prefix in that bucket.
