{
	"name": "youni",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"@cloudflare/workers-types": "^4.20251213.0",
			"hono": "^4.8.2",
			"@orpc/server": "^1.13.14",
			"@orpc/openapi": "^1.13.14",
			"@orpc/zod": "^1.13.14",
			"better-auth": "1.6.9",
			"ai": "^6.0.3",
			"alchemy": "^0.91.2",
			"next-themes": "^0.4.6",
			"@orpc/tanstack-query": "^1.13.14",
			"@orpc/client": "^1.13.14",
			"@tanstack/react-query": "^5.90.12",
			"@tanstack/react-form": "^1.28.0",
			"@ai-sdk/react": "^3.0.3",
			"@types/react-dom": "^19.2.3",
			"@better-auth/expo": "1.6.9",
			"drizzle-orm": "^0.45.1",
			"@types/pg": "^8.16.0"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:native": "turbo -F native dev",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F server dev",
		"db:push": "turbo -F @youni/db db:push",
		"db:seed": "turbo -F @youni/db db:seed",
		"db:studio": "turbo -F @youni/db db:studio",
		"db:generate": "turbo -F @youni/db db:generate",
		"db:migrate": "turbo -F @youni/db db:migrate",
		"deploy": "turbo -F @youni/infra deploy",
		"destroy": "turbo -F @youni/infra destroy",
		"check": "biome check --write ."
	},
	"dependencies": {
		"@youni/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@cloudflare/workers-types": "catalog:",
		"@types/node": "^22.13.14",
		"@youni/config": "workspace:*",
		"turbo": "^2.8.12",
		"typescript": "^6"
	},
	"packageManager": "bun@1.3.10"
}
