# Server
CORS_ORIGIN="http://localhost:3001,http://127.0.0.1:3001,http://localhost:8081,http://127.0.0.1:8081"
BETTER_AUTH_SECRET="replace-with-a-random-secret-at-least-32-characters"
BETTER_AUTH_URL="http://localhost:3000"

# Optional. If left empty in local development, password reset links are printed in server logs.
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# D1 database named `youni`. Required by `bun run db:migrate` and `bun run db:seed`.
CLOUDFLARE_D1_DATABASE_ID=""

# Google OAuth
GOOGLE_WEB_CLIENT_ID=""
GOOGLE_IOS_CLIENT_ID=""
GOOGLE_ANDROID_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional direct R2 access when running the server outside Alchemy.
# The Cloudflare account id is read from `packages/infra/.env`.
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="youni"
