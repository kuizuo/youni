{
	"expo": {
		"owner": "kuizuo",
		"scheme": "youni",
		"updates": {
			"url": "https://u.expo.dev/b9972331-7d91-43c0-ad64-3282d625f644"
		},
		"runtimeVersion": {
			"policy": "sdkVersion"
		},
		"ios": {
			"bundleIdentifier": "com.kuizuo.youni",
			"infoPlist": {
				"ITSAppUsesNonExemptEncryption": false
			}
		},
		"userInterfaceStyle": "automatic",
		"orientation": "default",
		"icon": "./assets/images/icon.png",
		"android": {
			"package": "com.kuizuo.youni",
			"adaptiveIcon": {
				"foregroundImage": "./assets/images/android-icon-foreground.png",
				"backgroundImage": "./assets/images/android-icon-background.png",
				"monochromeImage": "./assets/images/android-icon-monochrome.png"
			}
		},
		"web": {
			"bundler": "metro",
			"favicon": "./assets/images/favicon.png"
		},
		"name": "youni",
		"slug": "youni",
		"plugins": [
			"expo-router",
			[
				"expo-build-properties",
				{
					"ios": {
						"useFrameworks": "static"
					}
				}
			],
			[
				"expo-splash-screen",
				{
					"image": "./assets/images/splash-icon.png",
					"imageWidth": 200,
					"resizeMode": "contain",
					"backgroundColor": "#ffffff",
					"dark": {
						"backgroundColor": "#000000"
					}
				}
			],
			"expo-font",
			"expo-notifications",
			"expo-secure-store",
			"expo-web-browser",
			[
				"expo-camera",
				{
					"cameraPermission": "允许 Youni 使用相机拍摄笔记照片。",
					"recordAudioAndroid": false
				}
			],
			[
				"expo-image-picker",
				{
					"photosPermission": "允许 Youni 访问照片，用于发布笔记和选择头像。",
					"microphonePermission": false
				}
			],
			[
				"expo-media-library",
				{
					"photosPermission": "允许 Youni 访问照片，用于发布笔记和选择头像。",
					"savePhotosPermission": false,
					"preventAutomaticLimitedAccessAlert": true,
					"granularPermissions": ["photo"]
				}
			]
		],
		"experiments": {
			"typedRoutes": true,
			"reactCompiler": true
		},
		"extra": {
			"eas": {
				"projectId": "b9972331-7d91-43c0-ad64-3282d625f644"
			}
		}
	}
}
