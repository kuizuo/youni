{
	"name": "native",
	"version": "1.2.1",
	"private": true,
	"main": "expo-router/entry",
	"scripts": {
		"start": "expo start",
		"dev": "expo start --dev-client --clear",
		"android": "expo run:android",
		"ios": "expo run:ios",
		"prebuild": "expo prebuild",
		"web": "expo start --web",
		"build:web": "EXPO_PUBLIC_SERVER_URL=https://youni-api.kuizuo.me expo export --platform web",
		"build:ios": "EXPO_PUBLIC_SERVER_URL=https://youni-api.kuizuo.me expo run:ios --configuration Release",
		"build:android": "EXPO_PUBLIC_SERVER_URL=https://youni-api.kuizuo.me expo run:android --variant release",
		"build:eas": "EAS_BUILD_NO_EXPO_GO_WARNING=true bunx eas-cli@latest build --platform all --profile production",
		"build:eas:android": "EAS_BUILD_NO_EXPO_GO_WARNING=true bunx eas-cli@latest build --platform android --profile production",
		"build:eas:android-internal": "EAS_BUILD_NO_EXPO_GO_WARNING=true bunx eas-cli@latest build --platform android --profile preview",
		"build:eas:ios": "EAS_BUILD_NO_EXPO_GO_WARNING=true bunx eas-cli@latest build --platform ios --profile production",
		"update:preview": "bunx eas-cli@latest update --channel preview --environment production",
		"update:production": "bunx eas-cli@latest update:republish --destination-channel production"
	},
	"dependencies": {
		"@better-auth/expo": "catalog:",
		"@expo-google-fonts/nunito": "^0.4.2",
